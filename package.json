{
  "name": "chai-wait-for",
  "version": "0.0.0-development",
  "description": "Drop-in replacement for expect that waits for the assertion to succeed (retries on an interval you choose, until a timeout you choose)",
  "sideEffects": false,
  "scripts": {
    "tc": "toolchain",
    "toolchain": "toolchain",
    "test": "toolchain test",
    "prepublishOnly": "echo This package is meant to be published by semantic-release from the dist build directory. && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jcoreio/chai-wait-for.git"
  },
  "keywords": [
    "chai",
    "wait",
    "await",
    "async",
    "async-await",
    "poll",
    "assertion",
    "retry"
  ],
  "author": "Andy Edwards",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jcoreio/chai-wait-for/issues"
  },
  "homepage": "https://github.com/jcoreio/chai-wait-for#readme",
  "devDependencies": {
    "@jcoreio/toolchain": "^5.5.5",
    "@jcoreio/toolchain-circle": "^5.5.5",
    "@jcoreio/toolchain-esnext": "^5.5.5",
    "@jcoreio/toolchain-mocha": "^5.5.5",
    "@jcoreio/toolchain-semantic-release": "^5.5.5",
    "@jcoreio/toolchain-typescript": "^5.5.5",
    "chai": "^6.0.1",
    "chai-as-promised": "^8.0.2",
    "chai-subset": "^1.6.0",
    "chai-webdriverio-async": "^2.0.0",
    "chai4": "npm:chai@^4",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^7.0.0",
    "globals": "^16.0.0",
    "lint-staged": "^15.2.2",
    "lodash": "^4.17.20",
    "mocha": "^10.2.0",
    "nyc": "^15.1.0",
    "prettier": "^3.4.2",
    "sinon": "^9.2.2",
    "typescript": "^5.2.2"
  },
  "peerDependencies": {
    "chai": ">=4 <7"
  },
  "dependencies": {
    "@babel/runtime": "^7.26.0",
    "@types/chai": "^4.3.10"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=16"
  },
  "packageManager": "pnpm@10.6.5",
  "@jcoreio/toolchain": {
    "migratedVersion": "5.5.5"
  }
}
